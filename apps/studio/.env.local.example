# ============================================================
#  SP Studio — Environment Variables
#  Copy to: apps/studio/.env.local
#  NEVER commit .env.local to Git
# ============================================================

# ── Anthropic ────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
# Also retrievable from PasswordN at key: ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ─────────────────────────────────────────────────
# Get from: Supabase dashboard → Project Settings → API
# Use the SERVICE ROLE key (not anon key — RLS blocks anon)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Vercel Deploy API ─────────────────────────────────────────
# Get from: vercel.com → Account Settings → Tokens
# Token needs: Deploy scope on strategypresentation project
VERCEL_TOKEN=your_vercel_token_here
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxx    # from Vercel project settings
VERCEL_TEAM_ID=team_xxxxxxxxxxxx      # optional — only if using a team account

# ── Inter-app Security (WCS ↔ SP Studio) ────────────────────
# Generate with: openssl rand -hex 32
# This SAME value must be set in WCS as SP_WEBHOOK_SECRET
# Also store in PasswordN at key: SP_WEBHOOK_SECRET
SP_WEBHOOK_SECRET=your_64_char_hex_secret_here

# ── Studio Local Auth ─────────────────────────────────────────
# Simple passphrase for the local studio UI
# Also used as x-studio-passphrase header in API calls
# Also store in PasswordN at key: SP_STUDIO_PASSPHRASE
STUDIO_PASSPHRASE=HansStudio2026

# Exposed to browser (needed for the React client to send auth header)
NEXT_PUBLIC_STUDIO_PASSPHRASE=HansStudio2026

# ── Node env ─────────────────────────────────────────────────
NODE_ENV=development
